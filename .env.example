# ── LOLance Environment Configuration ──────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control!

# Environment: development | production
APP_ENV=production
APP_DOMAIN=lolance.com

# Database
DB_HOST=127.0.0.1
DB_NAME=lolance
DB_USER=lolance_user
DB_PASS=CHANGE_ME_STRONG_DB_PASSWORD

# Session
SESSION_NAME=lolance_session

# Email / SMTP (Gmail App Password)
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=LOLance
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD

# Legal document versions
TERMS_VERSION=2026-04-01
PRIVACY_VERSION=2026-04-01

# Admin secret for deposit/withdrawal verification
# Generate with: php -r "echo bin2hex(random_bytes(32));"
ADMIN_SECRET=CHANGE_ME_RANDOM_SECRET_KEY

# Rate limiting
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Crypto wallets — set your own addresses
CRYPTO_WALLET_TRC20=YOUR_TRC20_ADDRESS
CRYPTO_WALLET_BEP20=YOUR_BEP20_ADDRESS
CRYPTO_WALLET_ERC20=YOUR_ERC20_ADDRESS
CRYPTO_WALLET_BTC=YOUR_BTC_ADDRESS

# Economy
COINS_PER_USD=100.0
MIN_DEPOSIT_USD=1.0
MAX_DEPOSIT_USD=10000.0
DEPOSIT_EXPIRE_MINUTES=60

# Crypto rate cache TTL in seconds (300 = 5 min)
CRYPTO_RATE_CACHE_TTL=300

# Rate limits: ACTION_MAX=max attempts, ACTION_WINDOW=window in minutes
RATE_LIMIT_DEPOSIT_MAX=5
RATE_LIMIT_DEPOSIT_WINDOW=15
RATE_LIMIT_WITHDRAW_MAX=3
RATE_LIMIT_WITHDRAW_WINDOW=60
RATE_LIMIT_TIP_MAX=20
RATE_LIMIT_TIP_WINDOW=60
RATE_LIMIT_XP_MAX=10
RATE_LIMIT_XP_WINDOW=60
RATE_LIMIT_CHAT_MAX=60
RATE_LIMIT_CHAT_WINDOW=5
RATE_LIMIT_TASK_MAX=10
RATE_LIMIT_TASK_WINDOW=60
RATE_LIMIT_MSG_MAX=30
RATE_LIMIT_MSG_WINDOW=5
RATE_LIMIT_SUPPORT_MAX=10
RATE_LIMIT_SUPPORT_WINDOW=60
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_REGISTER_WINDOW=15

# Redis (optional — used for leaderboard/crypto-rate caching)
# Leave REDIS_HOST empty to use file-based cache fallback
REDIS_HOST=
REDIS_PORT=6379
REDIS_PREFIX=lolance:
