# ══════════════════════════════════════════════════════════════════
# Lolanceizi — Production .env для Hostinger
# Версія: 2026-04-07
#
# ІНСТРУКЦІЯ:
#   1. Скопіюй цей файл як .env на сервер
#   2. Заповни значення позначені ← ЗАМІНИ
#   3. НІКОЛИ не коміть .env в git!
# ══════════════════════════════════════════════════════════════════

# ── Середовище ─────────────────────────────────────────────────────
APP_ENV=production
APP_DOMAIN=lolanceizi.online

# ── База даних (Hostinger) ─────────────────────────────────────────
# ВАЖЛИВО: На Hostinger DB_HOST = localhost (НЕ 127.0.0.1)
# Назви БД мають префікс Hostinger (наприклад u123456789_)
DB_HOST=localhost
DB_NAME=u123456789_lolanceizi
DB_USER=u123456789_lolanceizi_user
DB_PASS=←_ЗАМІНИ_НА_ПАРОЛЬ_БАЗИ_ДАНИХ

# ── Сесія ──────────────────────────────────────────────────────────
SESSION_NAME=lolanceizi_session

# ── Email / SMTP ───────────────────────────────────────────────────
# Варіант A: Gmail (потрібен App Password з 2FA)
# Варіант B: Hostinger Email (smtp.hostinger.com)
MAIL_FROM=←_ЗАМІНИ_НА_EMAIL
MAIL_FROM_NAME=Lolanceizi
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=←_ЗАМІНИ_НА_EMAIL
SMTP_PASS=←_ЗАМІНИ_НА_APP_PASSWORD

# ── Юридичні документи ─────────────────────────────────────────────
TERMS_VERSION=2026-04-01
PRIVACY_VERSION=2026-04-01

# ── Admin Secret (для cron-verify та admin endpoints) ──────────────
# Згенерований випадковий ключ — можеш використати цей або згенерувати свій:
# php -r "echo bin2hex(random_bytes(32));"
ADMIN_SECRET=c1eb2c8c0c0cbd6a76cbfe5fcffebb03d783aeb9d6f258abdfe21362f1e05f93

# ── Rate Limiting ──────────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ── Крипто гаманці (для прийому депозитів) ─────────────────────────
# Залиш пустими якщо крипто поки не потрібно
CRYPTO_WALLET_TRC20=
CRYPTO_WALLET_BEP20=
CRYPTO_WALLET_ERC20=
CRYPTO_WALLET_BTC=

# ── Економіка ──────────────────────────────────────────────────────
COINS_PER_USD=100.0
MIN_DEPOSIT_USD=1.0
MAX_DEPOSIT_USD=10000.0
DEPOSIT_EXPIRE_MINUTES=60

# ── Комісії платформи (%) ──────────────────────────────────────────
DEPOSIT_FEE_PCT=3.0
TASK_CREATE_FEE_PCT=2.5
TASK_COMPLETE_FEE_PCT=4.0
MINIGAME_FEE_PCT=0.1

# ── Кеш крипто-курсів (секунди) ───────────────────────────────────
CRYPTO_RATE_CACHE_TTL=300

# ── Rate Limits (значення за замовчуванням — ОК для продакшену) ────
RATE_LIMIT_DEPOSIT_MAX=5
RATE_LIMIT_DEPOSIT_WINDOW=15
RATE_LIMIT_WITHDRAW_MAX=3
RATE_LIMIT_WITHDRAW_WINDOW=60
RATE_LIMIT_TIP_MAX=20
RATE_LIMIT_TIP_WINDOW=60
RATE_LIMIT_XP_MAX=10
RATE_LIMIT_XP_WINDOW=60
RATE_LIMIT_CHAT_MAX=60
RATE_LIMIT_CHAT_WINDOW=5
RATE_LIMIT_TASK_MAX=10
RATE_LIMIT_TASK_WINDOW=60
RATE_LIMIT_MSG_MAX=30
RATE_LIMIT_MSG_WINDOW=5
RATE_LIMIT_SUPPORT_MAX=10
RATE_LIMIT_SUPPORT_WINDOW=60
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_REGISTER_WINDOW=15

# ── Redis (на Hostinger shared hosting — НЕ доступний) ─────────────
# Залиш пустим — автоматичний file-based cache fallback
REDIS_HOST=
REDIS_PORT=6379
REDIS_PREFIX=lolanceizi:
